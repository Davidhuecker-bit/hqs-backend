# Core runtime
PORT=8080
RUN_JOBS=false
DATABASE_URL=

# Frontend domains allowed by CORS (comma-separated literal origins)
CORS_ORIGINS=

# External providers
# Configure at least one market data provider for quotes/historical data.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
FMP_API_KEY=
FINNHUB_API_KEY=
MASSIVE_API_KEY=
TWELVE_DATA_API_KEY=

# FX rate configuration
# Emergency static USD→EUR fallback when live API fails (e.g., 0.92)
# CRITICAL: Set this to prevent snapshot loss when FX API is down
FX_STATIC_USD_EUR=0.92
FX_USD_EUR_URL=https://api.exchangerate.host/latest?base=USD&symbols=EUR

# Optional distributed cache (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Operational tuning
UNIVERSE_REFRESH_HOUR=2
UNIVERSE_REFRESH_MINUTE=10
SNAPSHOT_BATCH_SIZE=80
MC_SIMS=800

# Scheduler overrides (all default to the values shown)
FORECAST_VERIFY_HOUR=3
FORECAST_VERIFY_MINUTE=0
CAUSAL_MEMORY_HOUR=4
CAUSAL_MEMORY_MINUTE=0
TECH_RADAR_HOUR=6
TECH_RADAR_MINUTE=0
