# Core runtime
PORT=8080
RUN_JOBS=false
DATABASE_URL=
PG_SSL_REJECT_UNAUTHORIZED=false

# Frontend domains allowed by CORS (comma-separated literal origins)
CORS_ORIGINS=

# External providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
FMP_API_KEY=
FINNHUB_API_KEY=
MASSIVE_API_KEY=
TWELVE_DATA_API_KEY=

# Optional distributed cache
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Operational tuning
UNIVERSE_REFRESH_HOUR=2
UNIVERSE_REFRESH_MINUTE=10
SNAPSHOT_BATCH_SIZE=80
MC_SIMS=800
