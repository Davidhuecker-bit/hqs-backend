# ══════════════════════════════════════════════════════════════════════════════
# HQS Backend – Environment Variables
# Copy this file to .env for local development.
# In Railway: add these variables via the Variables tab of each service.
# Variables marked REQUIRED must be set. Optional ones have working defaults.
# ══════════════════════════════════════════════════════════════════════════════

# ── Core runtime ──────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
# Set to true on the main web service; leave false on all cron/job services.
RUN_JOBS=false
DATABASE_URL=

# Frontend domains allowed by CORS (comma-separated literal origins).
# Example: https://app.example.com,https://staging.example.com
CORS_ORIGINS=

# ── Frontend project root (optional) ─────────────────────────────────────────
# Absolute path to the frontend project root.
# When set, findFileByName and readFile extend their scope to include:
#   src/, src/components/, src/views/, src/hooks/, src/services/,
#   src/utils/, src/pages/, src/layouts/, src/styles/, components/,
#   pages/, views/, public/  – all relative to FRONTEND_ROOT.
# READ access is granted to both agents (Gemini + DeepSeek).
# WRITE scope remains unchanged (role-based: Gemini → frontend, DeepSeek → backend).
# Secret/env/binary protection rules always apply.
# Example (monorepo): FRONTEND_ROOT=/app/frontend
# FRONTEND_ROOT=

# ── Admin API security ────────────────────────────────────────────────────────
# REQUIRED: shared secret for all /api/admin/* routes.
# Generate with: openssl rand -hex 32
# Access via header: X-Admin-Key: <value>
ADMIN_API_KEY=

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Window and max-requests for API and Admin route tiers (defaults shown).
# RATE_LIMIT_API_WINDOW_MIN=15
# RATE_LIMIT_API_MAX=100
# RATE_LIMIT_ADMIN_WINDOW_MIN=15
# RATE_LIMIT_ADMIN_MAX=30

# ── Error alerting (Slack webhook) ────────────────────────────────────────────
# Optional: Slack incoming webhook URL for job failure alerts.
# When set, every job that throws an unhandled error sends a Slack message.
# ALERT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxxxx

# ── Database startup ──────────────────────────────────────────────────────────
# How many times to retry the DB connection check on startup (default 10).
# STARTUP_DB_MAX_RETRIES=10
# Delay in ms between DB connection retries (default 3000).
# STARTUP_DB_RETRY_DELAY_MS=3000

# ── External market data providers ───────────────────────────────────────────
# Configure at least one market data provider for quotes/historical data.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── DeepSeek AI (optional) ────────────────────────────────────────────────────
# DeepSeek is accessed via the OpenAI SDK with a custom base URL.
# Set DEEPSEEK_API_KEY to enable the DeepSeek service and admin test endpoint.
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-reasoner
# DEEPSEEK_FAST_MODEL=deepseek-chat

# ── Gemini AI (optional) ──────────────────────────────────────────────────────
# Google Gemini is used by Gemini Architect V1 – the dedicated frontend/layout
# review assistant and the conference/war-room chat.
#
# ── Auth mode (explicit main switch) ─────────────────────────────────────────
# Set GEMINI_AUTH_MODE to force a specific auth mode. When not set, the mode is
# auto-detected from the credentials that are present.
#   GEMINI_AUTH_MODE=vertex_ai   → forces Vertex AI (recommended for production)
#   GEMINI_AUTH_MODE=gemini_api  → forces Gemini API (API key path)
# Vertex AI is the primary / preferred mode. Gemini API is the optional fallback.
# GEMINI_AUTH_MODE=vertex_ai
#
# ── Vertex AI (primary mode – ADC / service account) ─────────────────────────
# Set these to use Vertex AI. GEMINI_AUTH_MODE=vertex_ai is the explicit switch.
# Auto-detected when GOOGLE_CLOUD_PROJECT is set and GEMINI_AUTH_MODE is not.
# apiKey and vertexai params are NEVER mixed in the same client constructor.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-east4
# (legacy alias, used when GOOGLE_CLOUD_LOCATION is not set)
# GEMINI_LOCATION=us-east4
#
# ── Optional region fallback (Vertex AI) ──────────────────────────────────────
# When ENABLE_GEMINI_REGION_FALLBACK=true and both primary model and model
# fallback fail in the primary region, the backend retries the primary model
# in the fallback region before escalating to the Gemini API provider fallback.
# Default fallback location: us-west1
# ENABLE_GEMINI_REGION_FALLBACK=false
# GEMINI_FALLBACK_LOCATION=us-west1
#
# ── Gemini API (optional fallback) ───────────────────────────────────────────
# Set GEMINI_API_KEY to enable Gemini API as a fallback when Vertex AI is
# unavailable (requires ENABLE_GEMINI_FALLBACK=true).
# Do NOT use this as primary when Vertex AI is configured.
# GEMINI_API_KEY=
#
# ── Provider-level fallback (Vertex AI → Gemini API) ─────────────────────────
# When ENABLE_GEMINI_FALLBACK=true and GEMINI_API_KEY is set, the backend will
# fall back to the Gemini API if Vertex AI fails with:
#   • 404 model not available / not supported in this region
#   • 503 provider unavailable / temporary overload
#   • Region or endpoint connectivity issues
# No fallback for: auth/permission errors, payload/schema errors, safety blocks.
# ENABLE_GEMINI_FALLBACK=false
#
# ── Active mode reported by smoke-test endpoint ───────────────────────────────
#   GET /api/admin/deepseek/agent-bridge/gemini-smoke-test
#   Fields: authModeRequested, authModeUsed, fallbackUsed, projectConfigured,
#           locationConfigured, vertexFlagEnabled, apiKeyPresent,
#           primaryModel, finalModelUsed, errorCategory
#
# ── Model selection ───────────────────────────────────────────────────────────
#   Primary model  : gemini-2.5-flash  (default, overrideable via GEMINI_MODEL)
#   Fallback model : gemini-2.0-flash  (used automatically per-request when primary
#                    returns 503 / overloaded / model-not-found / 404)
#   • 429 rate-limit → retry/backoff only, no model switch
#   • 401/403 auth   → no fallback, error surfaced directly
# GEMINI_MODEL=gemini-2.5-flash

FMP_API_KEY=
FINNHUB_API_KEY=
MASSIVE_API_KEY=
TWELVE_DATA_API_KEY=
# Polygon.io – used as fallback universe source.
# POLYGON_API_KEY=

# Provider retry tuning (defaults shown, usually no need to change).
# MASSIVE_RETRIES=3
# TWELVE_DATA_RETRIES=2
# FMP_NEWS_TIMEOUT_MS=20000

# ── Massive Flatfiles (S3-compatible, us_stocks_sip/day_aggs_v1) ──────────────
# S3-compatible credentials for Massive flatfile access.
# REQUIRED for the historical flatfile backfill job and lazy backfill.
# Obtain from your Massive account settings / API credentials page.
MASSIVE_FLATFILES_ACCESS_KEY_ID=
MASSIVE_FLATFILES_SECRET_ACCESS_KEY=
# S3-compatible endpoint for Massive flatfiles (default shown).
MASSIVE_FLATFILES_ENDPOINT=https://files.massive.com
# S3 bucket name (default shown).
MASSIVE_FLATFILES_BUCKET=flatfiles
# AWS region (default: auto for non-AWS S3-compatible endpoints).
# MASSIVE_FLATFILES_REGION=auto
# Dataset path inside the bucket (default shown – daily US stock aggregates).
# MASSIVE_FLATFILES_DAILY_DATASET=us_stocks_sip/day_aggs_v1
# Whether to use path-style S3 URLs (true for non-AWS endpoints, default true).
# MASSIVE_FLATFILES_FORCE_PATH_STYLE=true
# In-memory file cache size (number of daily files to keep, default 3).
# MASSIVE_FLATFILES_CACHE_SIZE=3
# In-memory file cache TTL in ms (default 300000 = 5 min).
# MASSIVE_FLATFILES_CACHE_TTL=300000
# Max retries on transient S3 errors (default 3; 404/403/gzip errors are never retried).
# MASSIVE_FLATFILES_MAX_RETRIES=3
# Base delay in ms between retries (default 750).
# MASSIVE_FLATFILES_RETRY_BASE_DELAY_MS=750

# ── Historical price backfill tuning ─────────────────────────────────────────
# Minimum price points required before backfill is skipped (default 30).
# HISTORICAL_MIN_POINTS=30
# Days to look back for REST per-symbol backfill (default 730).
# HISTORICAL_BACKFILL_DAYS=730
# Set to false to disable flatfile bulk backfill (default true).
# HISTORICAL_ENABLE_FLATFILE_BACKFILL=true
# Max days to cover per symbol in flatfile bulk backfill (default 120).
# HISTORICAL_FLATFILE_MAX_DAYS=120
# Set to false to disable grouped daily backfill (default true).
# HISTORICAL_ENABLE_GROUPED_DAILY_BACKFILL=true
# Max days back to cover with grouped daily (default 30).
# HISTORICAL_GROUPED_DAILY_MAX_DAYS=30

# ── FX rate configuration ─────────────────────────────────────────────────────
# CRITICAL: Set FX_STATIC_USD_EUR to prevent snapshot loss when the FX API is down.
FX_STATIC_USD_EUR=0.92
FX_USD_EUR_URL=https://api.exchangerate.host/latest?base=USD&symbols=EUR
# In-memory cache duration for the FX rate in ms (default 15 minutes).
# FX_CACHE_MS=900000

# ── Universe / symbol configuration ──────────────────────────────────────────
# Max symbols loaded into the universe (default 300, max 5000).
# UNIVERSE_LIMIT=300
# Fallback limit if the main load fails (default 300, max 1000).
# FALLBACK_UNIVERSE_LIMIT=300
# Comma-separated Massive market codes to include (empty = all).
# Example: XNYS,XNAS,XETR
# UNIVERSE_MARKETS=
# Comma-separated locale codes to filter by (empty = all).
# UNIVERSE_LOCALES=
# Comma-separated asset types to include (empty = all).
# UNIVERSE_TYPES=
# Comma-separated symbol override list (bypasses universe query).
# SYMBOLS=AAPL,MSFT,NVDA

# ── Snapshot pipeline ─────────────────────────────────────────────────────────
# Number of symbols processed per snapshot batch (default 80).
SNAPSHOT_BATCH_SIZE=80
# Hard cap on symbols processed per snapshot run (default 250).
# SNAPSHOT_SYMBOL_LIMIT=250
# Market region for snapshot filtering, e.g. us, eu (default us).
# SNAPSHOT_REGION=us
# Fail the run if more than this many consecutive errors occur (default 35).
# SNAPSHOT_FAIL_FAST_THRESHOLD=35
# Warn if price deviates by more than this % from last snapshot (default unset).
# SNAPSHOT_PRICE_DEVIATION_WARN_PCT=
# Historical price period fetched per symbol (default 1y).
# HIST_PERIOD=1y
# Price sort order: asc or desc (default desc).
# PRICES_ORDER=desc

# ── Monte-Carlo simulation ─────────────────────────────────────────────────────
# Number of MC simulations per symbol scoring run (default 800).
MC_SIMS=800

# ── Discovery engine ──────────────────────────────────────────────────────────
# Max discoveries generated per run (default 10).
# DISCOVERY_LIMIT=10
# Days before the same symbol can be re-discovered (default 7).
# DISCOVERY_COOLDOWN_DAYS=7
# Outcome evaluation horizon in days (default 30).
# OUTCOME_HORIZON_DAYS=30

# ── Opportunity scanner / Guardian thresholds ─────────────────────────────────
# Volatility thresholds for the Guardian filter (defaults shown).
# GUARDIAN_THRESHOLD_SAFE=0.35
# GUARDIAN_THRESHOLD_VOLATILE=0.50
# GUARDIAN_THRESHOLD_DANGER=0.65
# Max news items fetched per symbol by opportunity scanner (default 5, max 10).
# OPPORTUNITY_NEWS_LIMIT=5

# ── Portfolio Twin / Capital Allocation ───────────────────────────────────────
# Total virtual investment budget in EUR (default 10000).
# ALLOCATION_BUDGET_EUR=10000
# Set to false to disable automatic position opening (default true).
# PORTFOLIO_TWIN_AUTO_OPEN=true
# Min HQS score to open a new position (default 50).
# SYNC_MIN_HQS_SCORE=50
# Max candidate symbols evaluated per sync run (default 20).
# SYNC_MAX_CANDIDATES=20
# Max simultaneously open positions (default 10).
# SYNC_MAX_OPEN_POSITIONS=10
# Max age of HQS score in hours before it is considered stale (default 48).
# SYNC_SCORE_MAX_AGE_H=48

# ── Forward learning ──────────────────────────────────────────────────────────
# Max entries processed per forward-learning run (default 40).
# FORWARD_LEARNING_LIMIT=40
# Minimum delay in minutes between forward-learning runs (default 10).
# FORWARD_LEARNING_MIN_DELAY_MINUTES=10

# ── Market news refresh ───────────────────────────────────────────────────────
# Max news articles fetched per symbol (default 5, max 20).
# MARKET_NEWS_LIMIT_PER_SYMBOL=5
# Max symbols processed per news refresh run (default 100, max 500).
# MARKET_NEWS_SYMBOL_LIMIT=100
# HTTP request timeout for news fetch in ms (default 20000, max 60000).
# MARKET_NEWS_REQUEST_TIMEOUT_MS=20000
# Max RSS feeds checked per symbol (default 3, max 10).
# MARKET_NEWS_MAX_FEEDS_PER_SYMBOL=3
# Minimum keyword match score to keep an article (default 2, max 20).
# MARKET_NEWS_MIN_MATCH_SCORE=2

# ── Admin insights / demo portfolio ──────────────────────────────────────────
# Default lookback window in hours for admin insight queries (default 24).
# ADMIN_LOOKBACK_HOURS=24
# Default long lookback in days for admin insight queries (default 7).
# ADMIN_LONG_LOOKBACK_DAYS=7
# TTL in ms for admin insight stack cache (default unset = no cache).
# ADMIN_STACK_TTL_MS=
# TTL in ms for the demo portfolio cache (default unset = always fresh).
# DEMO_PORTFOLIO_TTL_MS=
# TTL in ms for interface state cache (default unset = always fresh).
# INTERFACE_STATE_TTL_MS=
# Comma-separated symbols shown in the admin demo portfolio (default hardcoded list).
# DEMO_ADMIN_SYMBOLS=AAPL,MSFT,NVDA,AMZN,GOOGL
# Hours after which demo snapshot is considered stale (default 48).
# DEMO_SNAPSHOT_STALE_HOURS=48
# Hours after which demo score is considered stale (default 72).
# DEMO_SCORE_STALE_HOURS=72
# Hours after which demo metrics are considered stale (default 72).
# DEMO_METRICS_STALE_HOURS=72
# Hours after which demo news is considered stale (default 168 = 7 days).
# DEMO_NEWS_STALE_HOURS=168
# Hours after which demo snapshot is hard-stale (no longer served, default 168).
# DEMO_SNAPSHOT_HARD_STALE_HOURS=168

# ── Table health monitoring ───────────────────────────────────────────────────
# Row count threshold for GREEN status (default 5).
# TABLE_HEALTH_MIN_ROWS_GREEN=5
# Row count threshold for YELLOW status (default 1).
# TABLE_HEALTH_MIN_ROWS_YELLOW=1
# Hours since last write before a table is flagged as stale (default 48).
# TABLE_HEALTH_STALE_HOURS=48

# ── Data cleanup job ──────────────────────────────────────────────────────────
# All values are retention periods; data older than this will be deleted.
# DATA_CLEANUP_UNIVERSE_SCAN_KEEP_DAYS=7
# DATA_CLEANUP_LOCK_EXPIRY_HOURS=6
# DATA_CLEANUP_PIPELINE_STALE_HOURS=72
# DATA_CLEANUP_FX_RATES_KEEP_DAYS=90
# DATA_CLEANUP_SNAPSHOTS_KEEP_DAYS=180
# DATA_CLEANUP_HQS_SCORES_KEEP_DAYS=180
# DATA_CLEANUP_FACTOR_HISTORY_KEEP_DAYS=365
# DATA_CLEANUP_OUTCOME_TRACKING_KEEP_DAYS=180
# DATA_CLEANUP_DISCOVERY_HISTORY_KEEP_DAYS=180

# ── SEC EDGAR ─────────────────────────────────────────────────────────────────
# REQUIRED for SEC EDGAR service and refresh job.
# Must include a contact email as per SEC fair-use policy:
#   https://www.sec.gov/developer
SEC_EDGAR_USER_AGENT=YourApp contact@example.com
# SEC_EDGAR_BATCH_SIZE=50
# SEC_EDGAR_DELAY_MS=200
# SEC_EDGAR_FILING_LIMIT=12
# SEC_EDGAR_FACT_LIMIT=30
# SEC_EDGAR_TIMEOUT_MS=15000
# Override SEC EDGAR base URLs only if you mirror the data elsewhere.
# SEC_EDGAR_SUBMISSIONS_BASE_URL=https://data.sec.gov/submissions
# SEC_EDGAR_COMPANY_FACTS_BASE_URL=https://data.sec.gov/api/xbrl/companyfacts
# SEC_EDGAR_TICKER_MAP_URL=https://www.sec.gov/files/company_tickers.json

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# REQUIRED to send push notifications to web browsers.
# Generate ONCE with:
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k,null,2));"
# Then set:
VAPID_SUBJECT=mailto:admin@yourdomain.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Firebase (iOS/Android native push – optional) ─────────────────────────────
# Required only when device_type=ios or device_type=android tokens are registered.
# Set to the full JSON string of your Firebase service account key.
# FIREBASE_SERVICE_ACCOUNT=

# ── Smoke test ────────────────────────────────────────────────────────────────
# Base URL used by the smoke-check script (default http://localhost:3000).
# SMOKE_BASE_URL=https://your-railway-domain.up.railway.app
