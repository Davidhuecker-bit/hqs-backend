# Core runtime
PORT=8080
RUN_JOBS=false
DATABASE_URL=

# Frontend domains allowed by CORS (comma-separated literal origins)
CORS_ORIGINS=

# ── Admin API security ────────────────────────────────────────────────────────
# Required: shared secret for all /api/admin/* routes.
# Generate with: openssl rand -hex 32
# Access via header: X-Admin-Key: <value>
ADMIN_API_KEY=

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Window and max-requests for API and Admin route tiers (defaults shown).
# RATE_LIMIT_API_WINDOW_MIN=15
# RATE_LIMIT_API_MAX=100
# RATE_LIMIT_ADMIN_WINDOW_MIN=15
# RATE_LIMIT_ADMIN_MAX=30

# ── Error alerting (Slack webhook) ────────────────────────────────────────────
# Optional: Slack incoming webhook URL for job failure alerts.
# When set, every job that throws an unhandled error sends a Slack message.
# ALERT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxxxx

# External providers
# Configure at least one market data provider for quotes/historical data.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
FMP_API_KEY=
FINNHUB_API_KEY=
MASSIVE_API_KEY=
TWELVE_DATA_API_KEY=

# FX rate configuration
# Emergency static USD→EUR fallback when live API fails (e.g., 0.92)
# CRITICAL: Set this to prevent snapshot loss when FX API is down
FX_STATIC_USD_EUR=0.92
FX_USD_EUR_URL=https://api.exchangerate.host/latest?base=USD&symbols=EUR

# ── SEC EDGAR ─────────────────────────────────────────────────────────────────
# Required for SEC EDGAR service and refresh job.
# Must include a contact email as per SEC fair-use policy:
#   https://www.sec.gov/developer
SEC_EDGAR_USER_AGENT=YourApp contact@example.com
# SEC_EDGAR_BATCH_SIZE=50
# SEC_EDGAR_DELAY_MS=200
# SEC_EDGAR_FILING_LIMIT=12
# SEC_EDGAR_FACT_LIMIT=30

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Required to send push notifications to web browsers.
# Generate ONCE with:
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k,null,2));"
# Then set:
VAPID_SUBJECT=mailto:admin@yourdomain.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Firebase (iOS/Android native push – optional) ─────────────────────────────
# Required only when device_type=ios or device_type=android tokens are registered.
# Set to the full JSON string of your Firebase service account key.
# FIREBASE_SERVICE_ACCOUNT=

# Operational tuning
SNAPSHOT_BATCH_SIZE=80
MC_SIMS=800
