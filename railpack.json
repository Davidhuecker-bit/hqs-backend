{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "20",
    "python": "3.11"
  },
  "steps": {
    "install": {
      "inputs": [
        { "local": true, "include": ["package.json", "package-lock.json", "requirements.txt"] }
      ],
      "commands": [
        "npm ci",
        "pip3 install -r requirements.txt"
      ]
    }
  }
}
